                document.body.appendChild(note);
                noteCount++;
            
                colorChange(note, 'yellow');
                initializeNote(note);
                focusNote(note);
            }

            function focusNote(note) {
                highestZIndex += 2;
                note.style.zIndex = highestZIndex;
            }

            function removeNote(note) {
                note.parentNode.remove();
            }

            document.getElementById("bgImgButton").onclick = function() {
                bgImageUpload.click();
            };

            bgImageUpload.addEventListener("change", function() {
                const file = this.files[0];
                if (!file) return;
                if (!file.type.startsWith("image/")) {
                    alert("Please upload an image.");
                    return;
                }
                const imageURL = URL.createObjectURL(file);
                document.body.style.backgroundImage = `url(${imageURL})`;
            });
            
            function clearNotes() {
                document.querySelectorAll(".noteContainer").forEach(note => note.remove());
                noteCount = 0;
            }
        </script>
    </body>
</html>
