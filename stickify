<!DOCTYPE html>
<html>
    <head>
        <title>Stickify</title>
        <style>
            body {
                margin: 0;
                background-image: url("https://getwallpapers.com/wallpaper/full/c/6/5/96113.jpg");
                background-size: cover;
                background-position: center;
            }
            #topBar {
                position: absolute;
                top: 0;
                left: 0;
                width: 100vw;
                height: 10vh;
                background-color: #dd9f63;
                box-shadow: 0px 0px 15px;
                z-index: 9999;
            }
            .noteContainer {
                position: absolute;
                top: 100px;
                left: 10px;
                height: 250px;
                width: 250px;
                background-color: transparent;
                filter: drop-shadow(5px 5px 15px rgba(0,0,0,0.75));
                z-index: 2;
            }
            .noteContainer > #editable {
                position: absolute;
                top: 20%;
                left: 5%;
                width: 70%;
                height: 70%;
                background-color: transparent;
                outline: 0px;
                z-index: 2;
            }
            .noteContainer > #grabBar {
                position: absolute;
                top: 0;
                left: 0;
                height: 15%;
                width: 100%;
                background-color: #fff85c;
                z-index: 2;
                cursor: grab;
            }
            .noteContainer > #grabBar:active {
                cursor: grabbing;
            }
            .noteContainer > #cornerFlap {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 20%;
                aspect-ratio: 1 / 1;
                max-height: 25%;
                background: linear-gradient(to bottom right, #fff85c 50%, transparent 50%);
                z-index: 1;
                filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.2));
            }
            .noteContainer > #largeNoteBG {
                position: absolute;
                top: 0;
                left: 0;
                height: 80%;
                width: 80%;
                background-color: #fff740;
                z-index: 0;
            } .noteContainer > #bottomNoteBG {
                position: absolute;
                top: 80%;
                left: 0;
                height: 20%;
                width: 80%;
                background-color: #fff740;
                z-index: 0;
            }
            .noteContainer > #rightNoteBG {
                position: absolute;
                top: 15%;
                left: 80%;
                height: 65%;
                width: 20%;
                background-color: #fff740;
                z-index: 0;
            }
            .colorCircle {
                position: absolute;
                border-radius: 50%;
                height: 15%;
                aspect-ratio: 1 / 1;
    	        left: 50%;
    	        -ms-transform: translate(-50%, 0%);
    	        transform: translate(-50%, 0%);
                background-color: black;
            }
            #yellowCircle {
                top: 4.5%;
                background-color: #fff740;
            }
            #pinkCircle {
                top: 23.5%;
                background-color: #ff6fae;
            }
            #orangeCircle {
                top: 42.5%;
                background-color: #ff9f40;
            }
            #greenCircle {
                top: 61.5%;
                background-color: #5cd65c;
            }
            #blueCircle {
                top: 80.5%;
                background-color: #4fc3ff;
            }
        </style>
    </head>
    <body>
        <div id="topBar"></div>
        <div class="noteContainer">
            <div id="grabBar"></div>
            <div id="editable" contenteditable="true"></div>
            <div id="cornerFlap"></div>
            <div id="largeNoteBG"></div>
            <div id="rightNoteBG">
                <div id="yellowCircle" class="colorCircle" onclick="colorChange('yellow');"></div>
                <div id="pinkCircle" class="colorCircle" onclick="colorChange('pink');"></div>
                <div id="orangeCircle" class="colorCircle" onclick="colorChange('orange');"></div>
                <div id="greenCircle" class="colorCircle" onclick="colorChange('green');"></div>
                <div id="blueCircle" class="colorCircle" onclick="colorChange('blue');"></div>
            </div>
            <div id="bottomNoteBG"></div>
        </div>
        <script>
            const note = document.querySelector(".noteContainer");
            const grabBar = document.getElementById("grabBar");
            let isDragging = false;
            let offsetX = 0;
            let offsetY = 0;

            grabBar.addEventListener("mousedown", (e) => {
                isDragging = true;
                offsetX = e.clientX - note.offsetLeft;
                offsetY = e.clientY - note.offsetTop;
                document.body.style.userSelect = "none"
                note.style.filter = "drop-shadow(5px 5px 25px rgba(0, 0, 0, 0.75))";
            });

            document.addEventListener("mousemove", (e) => {
                if (!isDragging) return;
                note.style.left = (e.clientX - offsetX) + "px";
                note.style.top = (e.clientY - offsetY) + "px";
            });

            document.addEventListener("mouseup", (e) => {
                isDragging = false;
                document.body.style.userSelect = "auto";
                note.style.filter = "drop-shadow(5px 5px 15px rgba(0, 0, 0, 0.75))";
            });

            function colorChange(x) {
                let color = "";
                let accent = "";
                switch (x) {
                    case "yellow":
                        color = "#fff740";
                        accent = "#fff85c";
                        break;
                    case "pink":
                        color = "#ff6fae";
                        accent = "#ff8fc2";
                        break;
                    case "orange":
                        color = "#ff9f40";
                        accent = "#ffb366";
                        break;
                    case "green":
                        color = "#5cd65c";
                        accent = "#7be67b";
                        break;
                    case "blue":
                        color = "#4fc3ff";
                        accent = "#6fd0ff";
                        break;
                }
                let largeBG = document.querySelector("#largeNoteBG");
                let rightBG = document.querySelector("#rightNoteBG");
                let bottomBG = document.querySelector("#bottomNoteBG");
                let grabBar = document.querySelector("#grabBar");
                let cornerFlap = document.querySelector("#cornerFlap");

                largeBG.style.backgroundColor = color;
                rightBG.style.backgroundColor = color;
                bottomBG.style.backgroundColor = color;
                grabBar.style.backgroundColor = accent;
                cornerFlap.style.background = "linear-gradient(to bottom right, " + accent + " 50%, transparent 50%)";
                // add accent thingies next
            }
        </script>
    </body>
</html>
