<!DOCTYPE html>
<html>
    <head>
        <title>Stickify</title>
        <style>
            body {
                margin: 0;
                background-image: url("https://getwallpapers.com/wallpaper/full/c/6/5/96113.jpg");
                background-size: cover;
                background-position: top;
                overflow: hidden;
            }
            #topBar {
                position: absolute;
                top: 0;
                left: 0;
                width: 100vw;
                height: 10vh;
                background-color: #dd9f63;
                box-shadow: 0px 0px 15px;
                z-index: 9999;
            }
            .noteContainer {
                position: absolute;
                top: 100px;
                left: 10px;
                height: 250px;
                width: 250px;
                background-color: transparent;
                filter: drop-shadow(5px 5px 15px rgba(0,0,0,0.75));
            }
            .editable {
                position: absolute;
                top: 20%;
                left: 5%;
                width: 70%;
                height: 70%;
                background-color: transparent;
                outline: 0px;
                z-index: 1;
            }
            .grabBar {
                position: absolute;
                top: 0;
                left: 0;
                height: 15%;
                width: 100%;
                background-color: #fff85c;
                cursor: grab;
            }
            .grabBar:active {
                cursor: grabbing;
            }
            .cornerFlap {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 20%;
                aspect-ratio: 1 / 1;
                max-height: 25%;
                background: linear-gradient(to bottom right, #fff85c 50%, transparent 50%);
                filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.2));
            }
            .cornerFlap:hover {
                cursor: pointer;
            }
            .largeNoteBG {
                position: absolute;
                top: 15%;
                left: 0;
                height: 65%;
                width: 80%;
                background-color: #fff740;
            }
            .bottomNoteBG {
                position: absolute;
                top: 80%;
                left: 0;
                height: 20%;
                width: 80%;
                background-color: #fff740;
            }
            .rightNoteBG {
                position: absolute;
                top: 15%;
                left: 80%;
                height: 65%;
                width: 20%;
                background-color: #fff740;
            }
            .colorCircle {
                position: absolute;
                border-radius: 50%;
                height: 15%;
                aspect-ratio: 1 / 1;
    	        left: 50%;
    	        -ms-transform: translate(-50%, 0%);
    	        transform: translate(-50%, 0%);
                background-color: black;
                border: 1px dotted white;
            }
            .colorCircle:hover {
                cursor: pointer;
            }
            #yellowCircle {
                top: 4.5%;
                background-color: #fff740;
            }
            #pinkCircle {
                top: 23.5%;
                background-color: #ff6fae;
            }
            #orangeCircle {
                top: 42.5%;
                background-color: #ff9f40;
            }
            #greenCircle {
                top: 61.5%;
                background-color: #5cd65c;
            }
            #blueCircle {
                top: 80.5%;
                background-color: #4fc3ff;
            }
            #createNote {
                height: 80%;
                aspect-ratio: 1 / 1;
                position: absolute;
                top: 10%;
                left: 1%;
                background-color: transparent;
                border-style: outset;
                font-size: 2rem;
                text-align: center;
            }
            #createNote:hover {
                cursor: pointer;
            }
            #createNote:active {
                border-style: inset;
            }
        </style>
    </head>
    <body>
        <div id="topBar">
            <button id="createNote" title="Add Note" onclick="createNote();">+</button>
        </div>
        <div class="noteContainer">
            <div class="grabBar"></div>
            <div class="editable" contenteditable="true"></div>
            <div class="cornerFlap" title="Peel Off" onclick="removeNote(this);"></div>
            <div class="largeNoteBG"></div>
            <div class="rightNoteBG">
                <div id="yellowCircle" title="Yellow" class="colorCircle" onclick="colorChange(this, 'yellow');"></div>
                <div id="pinkCircle" title="Pink" class="colorCircle" onclick="colorChange(this, 'pink');"></div>
                <div id="orangeCircle" title="Orange" class="colorCircle" onclick="colorChange(this, 'orange');"></div>
                <div id="greenCircle" title="Green" class="colorCircle" onclick="colorChange(this, 'green');"></div>
                <div id="blueCircle" title="Blue" class="colorCircle" onclick="colorChange(this, 'blue');"></div>
            </div>
            <div class="bottomNoteBG"></div>
        </div>
        <script>
            let highestZIndex = 2;
            const note = document.querySelector(".noteContainer");
            const grabBar = document.getElementById("grabBar");
            let isDragging = false;
            let offsetX = 0;
            let offsetY = 0;
            let noteCount = 1;
            let activeNote = null;
            let maxNoteCount = 20;

            function initializeNote(note) {
                const grabBar = note.querySelector(".grabBar");
            
                grabBar.addEventListener("mousedown", e => {
            
                    activeNote = note;
                    focusNote(activeNote);
            
                    offsetX = e.clientX - note.offsetLeft;
                    offsetY = e.clientY - note.offsetTop;
            
                    document.body.style.userSelect = "none";
            
                    note.style.filter = "drop-shadow(5px 5px 25px rgba(0,0,0,0.75))";
            
                });
            
            }
            initializeNote(document.querySelector(".noteContainer"));

            document.addEventListener("mousemove", e => {
                if (!activeNote) return;

                let newX = (e.clientX - offsetX) + "px";
                let newY = (e.clientY - offsetY) + "px";
                
                activeNote.style.left = newX;
                activeNote.style.top = newY;
            });

            document.addEventListener("mouseup", () => {
                if (!activeNote) return;
            
                activeNote.style.filter = "drop-shadow(5px 5px 15px rgba(0,0,0,0.75))";
                activeNote = null;
                document.body.style.userSelect = "auto";
            });

            function colorChange(element, x) {
                const note = element.closest(".noteContainer"); 
                let color = "";
                let accent = "";
                switch (x) {
                    case "yellow":
                        color = "#fff740";
                        accent = "#fff85c";
                        break;
                    case "pink":
                        color = "#ff6fae";
                        accent = "#ff8fc2";
                        break;
                    case "orange":
                        color = "#ff9f40";
                        accent = "#ffb366";
                        break;
                    case "green":
                        color = "#5cd65c";
                        accent = "#7be67b";
                        break;
                    case "blue":
                        color = "#4fc3ff";
                        accent = "#6fd0ff";
                        break;
                }
                let largeBG = note.querySelector(".largeNoteBG");
                let rightBG = note.querySelector(".rightNoteBG");
                let bottomBG = note.querySelector(".bottomNoteBG");
                let grabBar = note.querySelector(".grabBar");
                let cornerFlap = note.querySelector(".cornerFlap");

                largeBG.style.backgroundColor = color;
                rightBG.style.backgroundColor = color;
                bottomBG.style.backgroundColor = color;
                grabBar.style.backgroundColor = accent;
                cornerFlap.style.background = "linear-gradient(to bottom right, " + accent + " 50%, transparent 50%)";
            }

            function createNote() {
                if (noteCount >= maxNoteCount) return;

                const original = document.querySelector(".noteContainer");
            
                const clone = original.cloneNode(true);
                const textBox = clone.querySelector(".editable");
                textBox.innerText = "";
                colorChange(clone, 'yellow');
            
                clone.style.left = ((noteCount * 15) + 10) + "px";
                clone.style.top = ((noteCount * 15) + 100) + "px";
                
                document.body.appendChild(clone);
                noteCount++;
            
                initializeNote(clone);
                focusNote(clone);
            }

            function focusNote(note) {
                highestZIndex += 2;
                note.style.zIndex = highestZIndex;
            }

            function removeNote(note) {
                note.parentNode.remove();
            }
        </script>
    </body>
</html>
