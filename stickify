<!DOCTYPE html>
<html>
    <head>
        <title>Stickify</title>
        <style>
            body {
                margin: 0;
                background-image: url("https://getwallpapers.com/wallpaper/full/c/6/5/96113.jpg");
                background-size: cover;
                background-position: top;
                overflow: hidden;
            }
            #topBar {
                position: absolute;
                top: 0;
                left: 0;
                width: 100vw;
                height: 10vh;
                background-color: #dd9f63;
                box-shadow: 0px 0px 15px;
                z-index: 9999;
            }
            .noteContainer {
                position: absolute;
                top: 100px;
                left: 10px;
                height: 250px;
                width: 250px;
                background-color: transparent;
                filter: drop-shadow(5px 5px 15px rgba(0,0,0,0.75));
            }
            .editable {
                position: absolute;
                top: 20%;
                left: 5%;
                width: 70%;
                height: 70%;
                background-color: transparent;
                outline: 0px;
                z-index: 1;
            }
            .grabBar {
                position: absolute;
                top: 0;
                left: 0;
                height: 15%;
                width: 100%;
                background-color: #fff85c;
                cursor: grab;
            }
            .grabBar:active {
                cursor: grabbing;
            }
            .cornerFlap {
                position: absolute;
                bottom: 0;
                right: 0;
                width: 20%;
                aspect-ratio: 1 / 1;
                max-height: 25%;
                background: linear-gradient(to bottom right, #fff85c 50%, transparent 50%);
                filter: drop-shadow(-2px -2px 3px rgba(0,0,0,0.2));
            }
            .cornerFlap:hover {
                cursor: pointer;
            }
            .largeNoteBG {
                position: absolute;
                top: 15%;
                left: 0;
                height: 65%;
                width: 80%;
                background-color: #fff740;
            }
            .bottomNoteBG {
                position: absolute;
                top: 80%;
                left: 0;
                height: 20%;
                width: 80%;
                background-color: #fff740;
            }
            .rightNoteBG {
                position: absolute;
                top: 15%;
                left: 80%;
                height: 65%;
                width: 20%;
                background-color: #fff740;
            }
            .colorScribble {
                position: absolute;
                height: 15%;
                width: 70%;
    	        left: 50%;
    	        -ms-transform: translate(-50%, 0%);
    	        transform: translate(-50%, 0%);
            }
            .colorScribble:hover {
                cursor: pointer;
            }
            #yellowScribble {
                top: 4.5%;
                fill: #fff740;
            }
            #pinkScribble {
                top: 23.5%;
                fill: #ff6fae;
            }
            #orangeScribble {
                top: 42.5%;
                fill: #ff9f40;
            }
            #greenScribble {
                top: 61.5%;
                fill: #5cd65c;
            }
            #blueScribble {
                top: 80.5%;
                fill: #4fc3ff;
            }
            #createNote {
                height: 80%;
                aspect-ratio: 1 / 1;
                position: absolute;
                top: 10%;
                left: 1%;
                background-color: transparent;
                border-style: outset;
                font-size: 2rem;
                text-align: center;
            }
            #createNote:hover {
                cursor: pointer;
            }
            #createNote:active {
                border-style: inset;
            }
            #bgImgChange {
                display: none;
            }
            #bgImgButton {
                height: 80%;
                aspect-ratio: 1 / 1;
                position: absolute;
                top: 10%;
                right: 1%;
                background-color: transparent;
                border-style: outset;
                font-size: 2rem;
                text-align: center;
            }
            #bgImgButton:hover {
                cursor: pointer;
            }
            #bgImgButton:active {
                border-style: inset;
            }
            #clearNotes {
                height: 80%;
                aspect-ratio: 1 / 1;
                position: absolute;
                top: 10%;
                left: 6%;
                background-color: transparent;
                border-style: outset;
                font-size: 2rem;
                text-align: center;
            }
            #clearNotes:hover {
                cursor: pointer;
            }
            #clearNotes:active {
                border-style: inset;
            }
        </style>
    </head>
    <body>
